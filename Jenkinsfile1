pipeline {
    agent any

    parameters {
        string(
            name: 'VERSION',
            defaultValue: '',
            description: 'Docker Image Version from CI'
        )
    }

    environment {
        DOCKERHUB_USERNAME = "harshalg01"
    
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout GitOps Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/harshal019/wanderlust-devsecops.git'

            }
        }

        stage('Validate Version') {
            steps {
                script {
                    if (!params.VERSION?.trim()) {
                        error("VERSION parameter is empty!")
                    }
                }
            }
        }

        stage('Update Kubernetes Image Tags') {
            steps {
                dir('kubernetes') {
                    sh """
                    sed -i 's|image: .*wanderlust-api.*|image: ${DOCKERHUB_USERNAME}/wanderlust-api:${params.VERSION}|g' backend.yml

                    sed -i 's|image: .*wanderlust-web.*|image: ${DOCKERHUB_USERNAME}/wanderlust-web:${params.VERSION}|g' frontend.yml
                    """
                }
            }
        }

        stage('Commit & Push Changes ') {
            steps {
                withCredentials([gitUsernamePassword(credentialsId: 'git-creds', gitToolName: 'Default')])
                {
                    sh """
                        echo "Checking repository status: "
                        git status
                        
                        echo "Adding changes to git: "
                        git add .
                            
                
                        git commit -m "Update image version to ${params.VERSION}" || echo "No changes to commit"

                        git push https://github.com/harshal019/wanderlust-devsecops.git main
                    """
                }
            }
        }
    }

    post {
        success {
            script {
                emailext attachLog: true,
                from: 'trainwithshubham@gmail.com',
                subject: "Wanderlust Application has been updated and deployed - '${currentBuild.result}'",
                body: """
                    <html>
                    <body>
                        <div style="background-color: #FFA07A; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">Project: ${env.JOB_NAME}</p>
                        </div>
                        <div style="background-color: #90EE90; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">Build Number: ${env.BUILD_NUMBER}</p>
                        </div>
                        <div style="background-color: #87CEEB; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">URL: ${env.BUILD_URL}</p>
                        </div>
                    </body>
                    </html>
            """,
            to: 'harshaldgharat01@gmail.com',
            mimeType: 'text/html'
            }
        }
      failure {
            script {
                emailext attachLog: true,
                from: 'trainwithshubham@gmail.com',
                subject: "Wanderlust Application build failed - '${currentBuild.result}'",
                body: """
                    <html>
                    <body>
                        <div style="background-color: #FFA07A; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">Project: ${env.JOB_NAME}</p>
                        </div>
                        <div style="background-color: #90EE90; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">Build Number: ${env.BUILD_NUMBER}</p>
                        </div>
                    </body>
                    </html>
            """,
            to: 'harshaldgharat01@gmail.com',
            mimeType: 'text/html'
            }
        }
    }
}